# Google AI API key — used for Gemini (planning, research, scripting) + image generation
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# Google Cloud API key — used for Text-to-Speech
GOOGLE_TTS_API_KEY=your_google_cloud_tts_api_key_here

# YouTube channel settings
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx
CHANNEL_NICHE=science facts
CHANNEL_LANGUAGE=es-MX

# TTS voice (Google Cloud TTS voice name)
TTS_VOICE=es-US-Chirp3-HD-Aoede

# Video upload schedule (UTC hours, comma-separated, must have 5 values)
UPLOAD_HOURS=8,10,12,14,16

# Optional: set to "private" for testing, "public" for production
DEFAULT_PRIVACY=public

# Optional: YouTube category ID (27=Education, 22=People & Blogs, 28=Science & Technology)
YOUTUBE_CATEGORY_ID=27
